<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>ca.wiilink.Patcher</id>

  <name>WiiLink Patcher</name>
  <summary>Get easily up and running with WiiLink!</summary>

  <developer id="ca.wiilink">
    <name>WiiLink</name>
  </developer>

  <metadata_license>MIT</metadata_license>
  <project_license>MPL-2.0</project_license>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <requires>
    <internet>always</internet>
  </requires>

  <content_rating type="oars-1.1" />

  <keywords>
    <keyword>Wii</keyword>
    <keyword>Homebrew</keyword>
    <keyword>WiiLink</keyword>
    <keyword>WiiConnect24</keyword>
  </keywords>

  <description>
    <p>
      WiiLink Patcher GUI is a Python application that helps you to get up and running with the WiiLink service. It automatically downloads and patches Wii channels from Nintendo’s servers to make them ready to install and use on a modded console.
    </p>
  </description>

  <launchable type="desktop-id">ca.wiilink.Patcher.desktop</launchable>

  <url type="bugtracker">https://github.com/WiiLink24/WiiLink-Patcher-GUI/issues</url>
  <url type="homepage">https://wiilink.ca</url>
  <url type="vcs-browser">https://github.com/WiiLink24/WiiLink-Patcher-GUI</url>

  <screenshots>
    <screenshot type="default">
      <image>https://github.com/WiiLink24/WiiLink-Patcher-GUI/raw/master/screenshots/main_menu.png?raw=true</image>
      <caption>Main menu</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/WiiLink24/WiiLink-Patcher-GUI/raw/master/screenshots/channel_selection.png?raw=true</image>
      <caption>Channel selection</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/WiiLink24/WiiLink-Patcher-GUI/raw/master/screenshots/patching.png?raw=true</image>
      <caption>Patching in progress</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.5.0" date="2026-04-12">
      <url type="details">https://github.com/WiiLink24/WiiLink-Patcher-GUI/releases/tag/v1.5.0</url>
      <description>
        <p>Release description:</p>
        <ul>
          <li>Added Food Channel Just Eat!</li>
          <li>Updated app icon</li>
        </ul>
      </description>
    </release>
    <release version="1.4.1" date="2026-03-12">
      <url type="details">https://github.com/WiiLink24/WiiLink-Patcher-GUI/releases/tag/v1.4.1</url>
      <description>
        <p>Release description:</p>
        <ul>
          <li>Fixed images in metainfo for Flatpak release.</li>
        </ul>
      </description>
    </release>
    <release version="1.4.0" date="2026-03-08">
      <url type="details">https://github.com/WiiLink24/WiiLink-Patcher-GUI/releases/tag/v1.4.0</url>
      <description>
        <p>Release description:</p>
        <ul>
          <li>First version to support Flatpak!</li>
          <li>Improved error messages</li>
          <li>Output path is now selected by the end user rather than defaulting to `~/Downloads/WiiLink`</li>
          <li>Fixed a crash when closing the app</li>
        </ul>
      </description>
    </release>
  </releases>
</component>

